{
    "position": "bottom",
    "height": 32,
    "spacing": 4,

    "modules-left": ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["custom/ytmusic"],
    "modules-right": ["custom/capslock", "tray", "custom/docker", "cpu", "memory", "custom/gpu", "custom/power", "pulseaudio", "custom/network", "custom/date", "clock"],

    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{icon}",
        "persistent-workspaces": {
            "1": [], "2": [], "3": [], "4": [], "5": [], "6": [], "7": [], "8": []
        },
        "format-icons": {
            "1": "蟀嫓", "2": "蟀姠", "3": "蟀", "4": "蟀枱", "5": "蟀姉", "6": "蟀喖", "7": "蟀潥", "8": "蟀嚠"
        }
    },

    "custom/docker": {
        "exec": "~/.config/waybar/scripts/docker-status.sh",
        "return-type": "json",
        "interval": 10,
        "on-click": "kitty --title lazydocker sh -c 'cd /mnt/main/dns && lazydocker'"
    },

    "cpu": {
        "format": "蟀崨  {usage}%",
        "tooltip-format": "CPU: {usage}%\nLoad: {load}",
        "interval": 2
    },

    "memory": {
        "format": "蟀槡  {avail:0.0f}GB",
        "tooltip-format": "Dispon铆vel: {avail:0.1f}GB\nUsado: {used:0.1f}GB / {total:0.1f}GB",
        "interval": 2
    },

    "custom/gpu": {
        "exec": "~/.config/waybar/scripts/gpu-usage.sh",
        "return-type": "json",
        "interval": 2
    },

    "custom/power": {
        "exec": "/home/lukesh/.config/waybar/scripts/power-status.sh",
        "return-type": "json",
        "interval": 300
    },

    "tray": {
        "spacing": 8
    },

    "hyprland/submap": {
        "format": "蟀┄  {}",
        "default-label": "",
        "tooltip": false
    },

    "custom/capslock": {
        "exec": "cat /sys/class/leds/input*::capslock/brightness 2>/dev/null | grep -qm1 '1' && echo '{\"text\": \"鈬猏", \"class\": \"on\"}' || echo '{\"text\": \"鈬猏", \"class\": \"off\"}'",
        "interval": 1,
        "return-type": "json",
        "format": "{}"
    },

    "custom/ytmusic": {
        "exec": "~/.config/waybar/scripts/ytmusic.sh",
        "return-type": "json",
        "interval": 2,
        "on-click": "playerctl -p $(playerctl -l 2>/dev/null | grep chromium | head -1) play-pause",
        "on-click-right": "playerctl -p $(playerctl -l 2>/dev/null | grep chromium | head -1) next",
        "max-length": 60
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "蟀杹  Muted",
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "format-icons": {
            "default": ["蟀暱", "蟀杸", "蟀暰"]
        }
    },

    "custom/network": {
        "exec": "~/.config/waybar/scripts/network-status.sh",
        "return-type": "json",
        "interval": 10
    },

    "custom/date": {
        "exec": "python3 ~/.config/waybar/scripts/calendar.py",
        "return-type": "json",
        "interval": 300,
        "format": "蟀笚  {}",
        "on-click": "bash ~/.config/waybar/scripts/calendar-popup.sh"
    },

    "clock": {
        "format": "蟀厫  {:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    }
}
